from collections import deque

# 1. Initialize
application_inbox = deque()
processed_history = []

# 2. Ingest Data
messy_startups = ["  TechCorp  ", "bio-gen", "  AI Labs ", "Fin-Tech  "]

for name in messy_startups:
    clean_name = name.strip().lower()
    application_inbox.append(clean_name)

# 3. Process (FIFO)
while application_inbox:
    name = application_inbox.popleft()
    print("Approving:", name)
    processed_history.append(name)

# 4. Undo (LIFO)
if processed_history:
    last_name = processed_history.pop()
    print("Reverting approval for:", last_name)
